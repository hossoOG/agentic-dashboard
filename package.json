{
  "name": "agenticexplorer",
  "private": false,
  "version": "1.4.0",
  "type": "module",
  "description": "Desktop app for managing and monitoring multiple Claude CLI sessions",
  "author": "hossoOG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hossoOG/agentic-dashboard.git"
  },
  "homepage": "https://github.com/hossoOG/agentic-dashboard",
  "bugs": {
    "url": "https://github.com/hossoOG/agentic-dashboard/issues"
  },
  "keywords": [
    "claude",
    "cli",
    "session-manager",
    "tauri",
    "desktop-app",
    "terminal",
    "ai",
    "agent"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'npx tsc --noEmit'",
      "eslint --max-warnings=0"
    ],
    "*.rs": [
      "bash -c 'cd src-tauri && cargo fmt --check'",
      "bash -c 'cd src-tauri && cargo check --quiet'"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
