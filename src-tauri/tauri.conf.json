{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgenticExplorer",
  "version": "1.2.5",
  "identifier": "dev.agentic.explorer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AgenticExplorer",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ws://localhost:* http://localhost:* https://api.github.com https://api.anthropic.com https://api.openai.com https://www.googleapis.com https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "startMenuFolder": "AgenticExplorer"
      }
    },
    "createUpdaterArtifacts": true,
    "shortDescription": "AgenticExplorer - Manage and monitor Claude CLI sessions"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCOThFRjM0NjNENjM4NApSV1NFWXoxRzg0NjVEY1dDd3NCU2puNTQ4Y1RBMXlRSHBodzN2ajNzNC92MFV1RFJFcGl4b2FmZAo=",
      "endpoints": [
        "https://github.com/hossoOG/agentic-dashboard/releases/latest/download/latest.json"
      ]
    }
  }
}
